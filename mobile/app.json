{
  "expo": {
    "name": "Square Up",
    "slug": "square-up",
    "scheme": "squareup",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1115"
    },
    "ios": {
      "bundleIdentifier": "com.mattbrill12.squareup",
      "supportsTablet": true
    },
    "android": {
      "package": "com.mattbrill12.squareup",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1115"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#ffcc33"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:8080"
    }
  }
}
